# ═══════════════════════════════════════
# .gitignore — Agentic RAG Project
# ═══════════════════════════════════════

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ── Virtual Environment ──
.venv/
venv/
ENV/
env/
.env.local

# ── Node.js ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── Logs ──
*.log
logs/

# ── Database & Vector Store ──
*.db
*.sqlite
*.sqlite3

# ── Uploaded Documents (اختياري) ──
# All_Invoices_Files/
*.pdf
*.docx
*.png
*.jpg
*.jpeg

# ── Generated Files ──
*.csv
*.json
!requirements.txt
!.env.example

# ── Secrets & Keys ──
.env
*.key
*.pem
*.crt

# ── OS Files ──
.DS_Store
Thumbs.db
desktop.ini

# ── Testing ──
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Jupyter Notebook ──
.ipynb_checkpoints

# ── Documentation ──
*.md.bak
docs/_build/

# ── Performance & Cache ──
*.cache
.huggingface/
.cache/

# ── Large Files (>50MB) ──
# models/
# datasets/
