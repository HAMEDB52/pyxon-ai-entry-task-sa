# ═══════════════════════════════════════
# Agentic RAG — Environment Variables (Example)
# ═══════════════════════════════════════
# انسخ هذا الملف إلى .env واملأ القيم الفعلية

# --- Google Gemini (مجاني) ---
# احصل على مفتاحك من: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- Neon PostgreSQL (Database) ---
# احصل عليها من: https://neon.tech
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# --- LangSmith (اختياري) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agentic-rag

# --- Langfuse (اختياري) ---
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Docling Settings ---
DOCLING_USE_GPU=false
DOCLING_TABLE_MODE=accurate

# --- Chunking Settings ---
CHUNK_MAX_TOKENS=512
CHUNK_MIN_TOKENS=64
CHUNK_OVERLAP=50

# --- Fixed Chunking ---
FIXED_CHUNK_SIZE=512
FIXED_CHUNK_OVERLAP=50

# --- Dynamic Chunking ---
DYNAMIC_MIN_CHUNK=128
DYNAMIC_MAX_CHUNK=1024
DYNAMIC_OVERLAP_PERCENT=0.1

# --- Semantic Chunking ---
SEMANTIC_MIN_SENTENCES=3
SEMANTIC_MAX_SENTENCES=10

# --- Agent Settings ---
MAX_RETRIES=3
VERIFICATION_THRESHOLD=0.7

# --- Upload Settings ---
MAX_UPLOAD_MB=20
UPLOAD_DIR=All_Invoices_Files

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=20
MAX_QUERY_LENGTH=2000
